{
  "productName": "OpenTimeSync",
  "version": "2.1.8",
  "identifier": "com.opentimesync.desktop",
  "build": {
    "frontendDist": "../public",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OpenTimeSync",
        "width": 800,
        "height": 500,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "title": "OpenTimeSync Startup",
        "url": "splash.html",
        "create": false,
        "width": 920,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1NkMwMEU0MzQ5QjQ0QTkKUldTcFJKczA1QUJzcFJxR05FTUFPTmVQL3pqcnZ0QzFkWVBXdnZwZllxYnJWUm4wdFRSbkxEdzcK",
      "endpoints": ["https://github.com/Qiguiqiang/OpenTimeSync/releases/latest/download/updater.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
