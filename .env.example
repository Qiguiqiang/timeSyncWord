# OpenTimeSync Environment Configuration
# Copy this to .env and modify as needed.

# Server
PORT=13013
SSL_PORT=13014

# SSL/HTTPS (generate certs with: bash scripts/generate-ssl.sh)
SSL_ENABLED=false
SSL_KEY_PATH=./certs/server.key
SSL_CERT_PATH=./certs/server.crt

# NTP Servers (comma-separated)
NTP_SERVERS=ntp.aliyun.com,ntp.tencent.com,time.asia.apple.com,time.google.com,pool.ntp.org

# Sync Settings
SYNC_SAMPLES_PER_SERVER=10
SYNC_OUTLIER_THRESHOLD=0.1
SYNC_RESYNC_INTERVAL=5000
SYNC_MAX_RTT=500

# Node
NODE_ENV=production
