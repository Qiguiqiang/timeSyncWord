{
  "name": "opentimesync",
  "version": "1.0.0",
  "description": "Browser-based high-precision time synchronization via NTP-weighted clock",
  "main": "electron/main.js",
  "author": "OpenTimeSync Contributors",
  "license": "MIT",
  "scripts": {
    "start": "node server/index.js",
    "electron": "node -e \"try{require('child_process').execSync('taskkill /f /im OpenTimeSync.exe 2>nul',{stdio:'ignore'})}catch(e){}\" && electron .",
    "build:win": "npx @electron/packager . OpenTimeSync --platform=win32 --arch=x64 --out=dist --overwrite",
    "build:mac": "npx @electron/packager . OpenTimeSync --platform=darwin --arch=x64 --out=dist --overwrite",
    "build:linux": "npx @electron/packager . OpenTimeSync --platform=linux --arch=x64 --out=dist --overwrite",
    "build:all": "npx @electron/packager . OpenTimeSync --platform=all --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.opentimesync.app",
    "productName": "OpenTimeSync",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  },
  "keywords": [
    "time-sync",
    "ntp",
    "synchronization",
    "browser",
    "electron"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5"
  }
}
